{
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "nextjs",
  "regions": ["hkg1"],
  "env": {
    "DATABASE_URL": {
      "description": "Supabase PostgreSQL数据库连接字符串"
    },
    "MINIMAX_API_KEY": {
      "description": "Minimax API密钥，用于命理分析"
    },
    "MINIMAX_API_BASE_URL": {
      "description": "Minimax API基础URL",
      "value": "https://api.minimax.chat/v1"
    },
    "NEXT_PUBLIC_APP_URL": {
      "description": "应用公开URL",
      "value": "https://your-app.vercel.app"
    }
  }
}